rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: own profile only + admin
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      // Owner can update own profile but cannot change role or status.
      // Admins can update anything.
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status
        )
      );
      allow delete: if false;
    }

    // Nurse profiles: nurse owns their own profile; marketplace remains readable to any signed-in user.
    match /nurseProfiles/{profileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Bookings: patient creates only their own; nurse + patient + admin can
    // read. Non-admin updates cannot mutate the booking's identity (patientId,
    // nurseId, createdAt, price) — only its status / rejection reason.
    match /bookings/{bookingId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.patientId ||
        request.auth.uid == resource.data.nurseId ||
        isAdmin()
      );
      allow create: if request.auth != null
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          (request.auth.uid == resource.data.nurseId || request.auth.uid == resource.data.patientId) &&
          request.resource.data.patientId == resource.data.patientId &&
          request.resource.data.nurseId == resource.data.nurseId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.price == resource.data.price
        )
      );
      allow delete: if isAdmin();
    }

    // Products: public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Care packages: public read (active packages drive marketing + booking),
    // admin-only writes. On first read the client auto-seeds default entries;
    // we allow signed-in users to create those seed docs so a fresh project
    // can bootstrap without manual admin intervention. Admins remain the only
    // role that can update or delete an existing package.
    match /packages/{packageId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Orders: patient owns (field is patientId, matching StoreOrder type), admin manages.
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.patientId || isAdmin()
      );
      allow create: if request.auth != null
        && request.resource.data.patientId == request.auth.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.patientId || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Community posts: public read (community feed is browseable), auth create, owner/admin manage.
    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.createdBy || isAdmin()
      );
    }

    // Medical records: patient reads own, nurse reads assigned, admin reads all.
    // Either the patient (self-recording) OR a nurse identifying themselves
    // can create a record. Required so nurses can close visits with a note.
    match /medicalRecords/{recordId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.patientId ||
        request.auth.uid == resource.data.nurseId ||
        isAdmin()
      );
      allow create: if request.auth != null && (
        request.resource.data.patientId == request.auth.uid ||
        request.resource.data.nurseId == request.auth.uid
      );
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.nurseId || isAdmin()
      );
      allow delete: if isAdmin();

      // Observations are scoped to the parent record's participants.
      match /observations/{obsId} {
        allow read: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/medicalRecords/$(recordId)).data.patientId ||
          request.auth.uid == get(/databases/$(database)/documents/medicalRecords/$(recordId)).data.nurseId ||
          isAdmin()
        );
        allow create: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/medicalRecords/$(recordId)).data.nurseId ||
          isAdmin()
        );
        allow update, delete: if isAdmin();
      }
    }

    // Reviews: public read (review counts power marketplace + dashboard),
    // patient creates only their own, owner can edit/delete their review,
    // admin can moderate.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.patientId || isAdmin()
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.patientId || isAdmin()
      );
    }

    // Notifications: recipient + admin can read. Any authenticated user can
    // create one (notifications flow between users — patient creates one for
    // nurse on booking, nurse creates one for patient on accept, etc.).
    // Recipients can only flip the read state; everything else is locked so
    // recipients can't rewrite the title/body or redirect the notification.
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          request.auth.uid == resource.data.userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])
        )
      );
      allow delete: if isAdmin();
    }

    // Patient profiles
    match /patientProfiles/{profileId} {
      allow read: if request.auth != null && (request.auth.uid == profileId || isAdmin());
      allow create, update: if request.auth != null && request.auth.uid == profileId;
      allow delete: if false;
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
